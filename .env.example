# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenRouter API — для текстовых моделей
OPENROUTER_API_KEY_TEXT=your_openrouter_key_here

# OpenRouter API — для генерации изображений
OPENROUTER_API_KEY_IMAGE=your_openrouter_key_here

# Базовый URL OpenRouter (менять не нужно)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Модели по умолчанию (опционально)
DEFAULT_TEXT_MODEL=anthropic/claude-3.5-sonnet
DEFAULT_IMAGE_MODEL=fal-ai/flux-pro

# Webhook (оставить пустым для polling)
WEBHOOK_BASE_URL=

# Уровень логирования
LOG_LEVEL=INFO
